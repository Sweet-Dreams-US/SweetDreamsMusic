{
  "framework": "nextjs",
  "git": {
    "deploymentEnabled": {
      "whitelabel": false
    }
  },
  "crons": [
    {
      "path": "/api/cron/session-reminders",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/fetch-metrics",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/priority-expiry",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/payment-reminders",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/lease-expiry",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/expire-entitlements",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/rewards-recompute",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/message-nudges",
      "schedule": "30 * * * *"
    },
    {
      "path": "/api/cron/tax-reminders",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/recurring-expenses",
      "schedule": "15 13 * * *"
    },
    {
      "path": "/api/cron/career-sweep",
      "schedule": "30 8 * * *"
    }
  ]
}
